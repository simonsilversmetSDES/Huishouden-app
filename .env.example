# Kopieer naar .env en vul echte waarden in. .env staat in .gitignore.

# --- Applicatie ---
APP_ENV=production                # production | development
SECRET_KEY=                       # sessie-signing, MIN. 32 tekens (bv. `openssl rand -hex 32`);
                                  # buiten development weigert de app te starten zonder veilige waarde
TZ=Europe/Brussels

# --- Database ---
# In Docker: sqlite:////data/db/huishouden.db (absoluut pad in de container).
# Lokaal zonder Docker: relatief aan de map waaruit je de backend start — vanuit
# backend/ is dat sqlite:///../data/db/huishouden-dev.db (zie README).
DATABASE_URL=sqlite:////data/db/huishouden.db

# --- Auth: 2 vaste accounts, argon2-hashes (genereer met scripts/hash_password.py) ---
# LET OP: verdubbel elke $ in de hash tot $$ (bv. $$argon2id$$v=19$$...), anders
# interpreteert Docker Compose de $-tekens als variabelen en wordt de hash verminkt.
SIMON_EMAIL=
SIMON_PASSWORD_HASH=
JOZEFIEN_EMAIL=
JOZEFIEN_PASSWORD_HASH=

# --- Rekening-IBAN's (CSV-import & detectie interne overschrijvingen) ---
# Zonder spaties of met — wordt genormaliseerd. Leeg laten = rekening zonder IBAN
# (CSV-import kan die rekening dan niet automatisch koppelen).
ACCOUNT_IBAN_KBC_ZICHT=           # gemeenschappelijke KBC-zichtrekening
ACCOUNT_IBAN_KBC_SPAAR=           # gemeenschappelijke KBC-spaarrekening
ACCOUNT_IBAN_FORTIS_ZICHT=        # Fortis-zichtrekening Simon
ACCOUNT_IBAN_FORTIS_SPAAR=        # Fortis-spaarrekening Simon
ACCOUNT_IBAN_JOZEFIEN_ZICHT=      # KBC-zichtrekening Jozefien

# --- Login rate limiting (brute-force-bescherming, per IP en per account) ---
LOGIN_MAX_ATTEMPTS=5              # mislukte pogingen vóór de eerste blokkade
LOGIN_BLOCK_BASE_SECONDS=30       # eerste blokkade; verdubbelt per extra mislukking
LOGIN_BLOCK_MAX_SECONDS=900       # plafond van de oplopende wachttijd (15 min)

# --- Sessies ---
SESSION_COOKIE_NAME=huishouden_session
SESSION_MAX_AGE_DAYS=7            # geldt voor cookie én server-side vervalcheck
SESSION_COOKIE_SECURE=true        # true achter Tailscale Serve (HTTPS)

# --- Koersen (yfinance) ---
PRICE_FETCH_ENABLED=true          # false = enkel manuele koersinvoer, geen externe calls
PRICE_FETCH_HOUR=18               # uur (lokale tijd) van de dagelijkse fetch

# --- Backups ---
BACKUP_ENABLED=true
BACKUP_DIR=/data/backups
BACKUP_RETENTION_DAYS=30
