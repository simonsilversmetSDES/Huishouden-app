# Kopieer naar .env en vul echte waarden in. .env staat in .gitignore.

# --- Applicatie ---
APP_ENV=production                # production | development
SECRET_KEY=                       # lange random string voor sessie-signing (bv. `openssl rand -hex 32`)
TZ=Europe/Brussels

# --- Database ---
# In Docker: sqlite:////data/db/huishouden.db (absoluut pad in de container).
# Lokaal zonder Docker: relatief aan de map waaruit je de backend start — vanuit
# backend/ is dat sqlite:///../data/db/huishouden-dev.db (zie README).
DATABASE_URL=sqlite:////data/db/huishouden.db

# --- Auth: 2 vaste accounts, argon2-hashes (genereer met scripts/hash_password.py) ---
# LET OP: verdubbel elke $ in de hash tot $$ (bv. $$argon2id$$v=19$$...), anders
# interpreteert Docker Compose de $-tekens als variabelen en wordt de hash verminkt.
SIMON_EMAIL=
SIMON_PASSWORD_HASH=
JOZEFIEN_EMAIL=
JOZEFIEN_PASSWORD_HASH=

# --- Sessies ---
SESSION_COOKIE_NAME=huishouden_session
SESSION_MAX_AGE_DAYS=30
SESSION_COOKIE_SECURE=true        # true achter Tailscale Serve (HTTPS)

# --- Koersen (yfinance) ---
PRICE_FETCH_ENABLED=true          # false = enkel manuele koersinvoer, geen externe calls
PRICE_FETCH_HOUR=18               # uur (lokale tijd) van de dagelijkse fetch

# --- Backups ---
BACKUP_ENABLED=true
BACKUP_DIR=/data/backups
BACKUP_RETENTION_DAYS=30
